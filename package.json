  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/LoonMaterials/Leave-You-Alone-Games/issues"
  },
  "homepage": "https://github.com/LoonMaterials/Leave-You-Alone-Games#readme",
  "dependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0"
  }
}
